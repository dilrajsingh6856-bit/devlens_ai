# Server Settings
PORT=8000
HOST=0.0.0.0

# Database Configuration
# Defaults to a local SQLite database if empty or not provided
# For PostgreSQL: postgresql://username:password@localhost:5432/devlens
DATABASE_URL=sqlite:///./devlens.db

# Security & Session Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# GitHub OAuth App Settings
# Obtain these from: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/oauth-callback

# AI / LLM Configuration
# Obtain your Gemini API Key from: https://aistudio.google.com/app/apikey
# If this is not provided, the server will load mock data for testing
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
